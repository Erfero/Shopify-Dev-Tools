# ── AI (required) ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── AI preset (optional) ───────────────────────────────────────────────────────
# Options: free | paid | paid_premium | best
# free        → Llama 3.3 70B (text) + Llama 4 Maverick (vision) — 0$/génération
# paid        → Mistral Small 3.2 (text) + Llama 4 Maverick (vision)
# paid_premium → Gemini 2.5 Flash (text+vision)
# best        → Claude 3.7 Sonnet (text+vision) — highest quality
AI_PRESET=best

# ── Manual model overrides (optional) ─────────────────────────────────────────
# AI_MODEL=anthropic/claude-3.7-sonnet
# AI_VISION_MODEL=anthropic/claude-3.7-sonnet

# ── Review generator ──────────────────────────────────────────────────────────
# Optional: upload review images to imgbb instead of local /uploads
IMGBB_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Database (optional) ───────────────────────────────────────────────────────
# Not set → SQLite at ./data/shopify_tools.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Theme customizer ──────────────────────────────────────────────────────────
TEMP_DIR=./temp
SESSION_TTL_SECONDS=14400

# Optional API token protection
# API_TOKEN=your_secret_token_here

# ── Development ───────────────────────────────────────────────────────────────
USE_MOCK=false
